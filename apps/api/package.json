{
  "name": "@peer-tutoring/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "build": "npm run build --workspace=@peer-tutoring/types && tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@peer-tutoring/types": "*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/multer": "^1.4.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "firebase-admin": "^13.0.0",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "rate-limiter-flexible": "^5.0.5",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "typescript": "^5.7.0",
    "uuid": "^10.0.0",
    "zod": "~3.24.0"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "tsx": "^4.22.4",
    "vitest": "^3.0.0"
  }
}
